abline(h=mean(Student_data$Marks), col = "red", lwd = 2, lty = 2)
abline(h=mean(Student_data$Marks), col = "red", lwd = 2, lty = 2)
text(x = 1.3, y = mean(Student_data$Marks),
labels = paste("Mean =", round(mean(Student_data$Marks))),
col = "red")
